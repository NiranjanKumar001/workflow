# ============================================
# WORKFLOW BACKEND - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.example and fill in your values
# NEVER commit .env.example to version control
# ============================================

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=jdbc:postgresql://localhost:5432/workflow_db
DB_USERNAME=postgres
DB_PASSWORD=nabin99

# ============================================
# JWT CONFIGURATION
# ============================================
# Generate a strong random secret (256+ bits)
# Example: openssl rand -base64 64
JWT_SECRET=MySecretKeyForJWTTokenGenerationMustBeAtLeast256BitsLongForHS256Algorithm

# ============================================
# OAUTH2 GOOGLE CONFIGURATION
# ============================================
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=74808369318-qu1b3taqbc3b0bnvtjr01ujkppcla1la.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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

# Redirect URI for OAuth2 callback
# Development: http://localhost:5173/auth/callback
# Production: https://yourdomain.com/auth/callback
OAUTH2_REDIRECT_URI=http://localhost:5173/auth/callback

# ============================================
# EMAIL CONFIGURATION
# ============================================
# Gmail account for sending emails
EMAIL_USERNAME=nabinoli986@gmail.com

# Gmail App Password (not your account password)
# Generate from: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=zqdr fjac mszs sayo

# From email address
EMAIL_FROM=nabinoli986@gmail.com

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# Frontend URL (for email links and CORS)
# Development: http://localhost:5173
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# ============================================
# CORS CONFIGURATION
# ============================================
# Comma-separated list of allowed origins
# Development: http://localhost:3000,http://localhost:5173
# Production: https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:4200

# ============================================
# SERVER CONFIGURATION
# ============================================
# Server port (default: 8080)
PORT=8080

# File upload directory
UPLOAD_DIR=uploads

