# ============================================
# WORKFLOW FRONTEND - ENVIRONMENT VARIABLES
# ============================================
# For Vite, all variables must start with VITE_
# ============================================

# ============================================
# API CONFIGURATION
# ============================================
# Backend API base URL
# Development: http://localhost:8080/api
# Production: https://api.yourdomain.com/api
VITE_API_BASE_URL=/api

# ============================================
# PRODUCTION DEPLOYMENT NOTES
# ============================================
# 1. Vercel: Set in Environment Variables (automatic .env support)
# 2. Netlify: Set in Build & Deploy > Environment
# 3. VPS/Docker: Create .env.production file
# 4. Build command will use .env.production automatically

# ============================================
# MULTIPLE ENVIRONMENT FILES
# ============================================
# .env                 - Default (loaded always)
# .env.local          - Local overrides (git ignored)
# .env.development    - Development mode
# .env.production     - Production mode
#
# Priority: .env.production > .env.local > .env
